#!/usr/bin/env ruby

require_relative '../lib/pr_d'
require 'optparse'

options = {}
OptionParser
  .new do |opts|
    opts.banner = 'Usage: prd [options]'
    opts.on('-f', '--file FILE', 'Specify the test file to run') { |file| options[:file] = file }
    opts.on('-o', '--out DIR', 'Specify the output directory') { |dir| options[:out] = dir }
    opts.on('-c', '--config FILE', 'Specify the config file') { |file| options[:config] = file }
    opts.on('-t', '--type TYPE', 'Specify the formatter type (simple, html, json)') do |type|
      options[:formatter] = type
    end
  end
  .parse!

raise 'No tests found. Please specify a test file using -f option.' if options[:file].nil? || options[:file].empty?
raise "Path not found: #{options[:file]}" unless File.exist?(options[:file])

tests =
  if File.directory?(options[:file])
    files = Dir[File.join(options[:file], '**', '*_spec.rb')].sort
    raise "No spec files found in directory: #{options[:file]}" if files.empty?
    files.map { |file| File.read(file) }
  elsif File.file?(options[:file])
    [File.read(options[:file])]
  end

io =
  if options[:out].nil?
    STDOUT
  else
    Dir.mkdir(options[:out]) unless Dir.exist?(options[:out])
    File.open(File.join(options[:out], 'report.qd'), 'w')
  end

formatter_class = case options[:formatter]
                  when nil, 'simple'
                    PrD::Formatters::SimpleFormatter
                  when 'html'
                    PrD::Formatters::HtmlFormatter
                  when 'json'
                    PrD::Formatters::JsonFormatter
                  else
                    raise "Unsupported formatter type: #{options[:formatter]}. Supported: simple, html, json"
                  end

serializers = {
  # Ferrum::Network::Exchange => (->(exchange) { exchange.url }),
  # PDF::Reader => (->(pdf) { pdf.pages.map(&:text).join("\n") })
}

formatter = formatter_class.new(io:, serializers:)
runtime = PrD::Runtime.new(formatter:, output_dir: options[:out], config_file: options[:config])
runtime.run(tests)
io.close if io != STDOUT
